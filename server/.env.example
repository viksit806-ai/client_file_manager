PORT=5000

# OLD Supabase (storage source for file migration)
OLD_SUPABASE_URL=https://your-old-project.supabase.co
OLD_SUPABASE_SERVICE_ROLE_KEY=your-old-service-role-key
OLD_SUPABASE_BUCKET=files

# NEW Supabase (destination for both data + storage)
SUPABASE_URL=https://your-new-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-new-service-role-key
SUPABASE_BUCKET=files

# MongoDB (source for structured data during migration)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ca_portal?retryWrites=true&w=majority

JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_EMAIL=admin@ca-firm.com
ADMIN_PASSWORD=your-admin-password
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
MAX_STORAGE_LIMIT=209715200
CORS_ORIGIN=http://localhost:3000,https://your-frontend.vercel.app
NODE_ENV=development
SLA_HOURS=48
WARNING_HOURS=12
